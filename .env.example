# ===== Deep Vision by DNS =====

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=deepvision
DB_USER=deepvision
DB_PASSWORD=changeme_secure_password

# JWT
JWT_SECRET=changeme_random_64_char_string
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# MinIO (S3-compatible storage)
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_USER=minioadmin
MINIO_PASSWORD=changeme_minio_password
MINIO_BUCKET_SNAPSHOTS=snapshots
MINIO_BUCKET_CLIPS=clips

# Redis
REDIS_URL=redis://redis:6379

# DeepStream / Detector
DETECTION_FPS=10
CONFIDENCE_THRESHOLD=0.5
MOTION_ON_THRESHOLD=0.005
MOTION_OFF_FRAMES=30
DEEPSTREAM_MODEL=yolov8m

# Retention
VIDEO_RETENTION_HOURS=48

# Nightly Job
NIGHTLY_START_HOUR=0
NIGHTLY_END_HOUR=5

# Alerts
WEBHOOK_URL=https://your-webhook-url
WHATSAPP_WEBHOOK_URL=https://your-whatsapp-api
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Vision Assistant (Ollama)
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
ASSISTANT_MODEL=phi3:mini

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
